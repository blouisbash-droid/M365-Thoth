# ─── MSP Azure AD App Registration ──────────────────────────────────────────────
#
# Register ONE app in the MSP's Azure AD tenant.
#
# App registration settings:
#   Supported account types: "Accounts in any organizational directory (Multi-tenant)"
#
# API Permissions — APPLICATION (not Delegated), admin consent granted in MSP tenant:
#   - AuditLog.Read.All        (read sign-in audit logs for customer tenants)
#   - Directory.Read.All       (read user/device directory info)
#
# API Permissions — DELEGATED (for MSP's own tenant when signed in):
#   - AuditLog.Read.All
#   - Directory.Read.All
#
# Required role for MSP sign-in (one of):
#   - Global Administrator, Security Administrator, Security Reader,
#     Global Reader, or Reports Reader
#
# Redirect URIs (Web):
#   - http://localhost:3000/api/auth/callback/azure-ad   (local dev)
#   - https://m365-ca-review.vercel.app/api/auth/callback/azure-ad
#   - https://m365-ca-review.vercel.app/tenants          (admin consent return URL)

AZURE_AD_CLIENT_ID="your-msp-app-client-id"
AZURE_AD_CLIENT_SECRET="your-msp-app-client-secret"
AZURE_AD_TENANT_ID="your-msp-tenant-id"

# ─── NextAuth ─────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your-random-secret-here"

# Production URL — no trailing slash
NEXTAUTH_URL="https://m365-ca-review.vercel.app"

# ─── Tenant Storage ───────────────────────────────────────────────────────────────
#
# Option A — Upstash Redis (recommended for dynamic add/remove without redeployment)
#   Add via Vercel dashboard: Project → Storage → Create → Upstash Redis
#   The two variables below are injected automatically after you connect the store.
#
# UPSTASH_REDIS_REST_URL="https://xxxxx.upstash.io"
# UPSTASH_REDIS_REST_TOKEN="AXxx..."
#
# Option B — Environment variable (static; requires redeployment to change)
#   JSON array of tenant objects. The UI on /tenants will generate this for you.
#
# TENANTS_CONFIG='[{"id":"uuid","name":"Contoso Corp","tenantId":"xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx","createdAt":"2026-01-01T00:00:00.000Z"}]'
